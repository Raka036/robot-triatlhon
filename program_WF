#include <Adafruit_PCF8574.h>
#include <elapsedMillis.h>
#include <SoftwareSerial.h>

#define HCRx 16
#define HCTx 15
SoftwareSerial HC05(HCRx, HCTx);

// PCF8574
Adafruit_PCF8574 pcf;

// millis
elapsedMillis millisLED;

// MOTOR
#define IN4 7
#define IN3 2
#define IN2 4
#define IN1 3
#define ENA 5
#define ENB 6

// ULTRASONIC
#define TRIGGER_PINF 10
#define ECHO_PINF 11
#define TRIGGER_PINL 8
#define ECHO_PINL 9 
#define TRIGGER_PINR 12
#define ECHO_PINR 13
#define MAX_DISTANCE 200

// SPEED
#define LEFT_BASE_SPEED 60
#define RIGHT_BASE_SPEED 55

// WALL FOLLOW
#define WALL_TARGET 5 
#define WALL_RANGE 4
#define FRONT_LIMIT 5

// BUTTON
#define BUTTON_PIN A6
#define BUTTON_THRESHOLD 100

// LED
#define INDICATOR_PIN 17
int BLINK_DELAY = 0;
bool currentLED = 0;

// MODES
#define MODE_STOP 0
#define MODE_LINE_FOLLOW 1
#define MODE_WALL_FOLLOW 2
#define MODE_BLUETOOTH 3
int currentMode = MODE_STOP;

// IR SENSOR
#define IR_LEFTMOST 0
#define IR_LEFT 1
#define IR_RIGHT 6
#define IR_RIGHTMOST 7

// ================= MOTOR =================

void motorControl(int in1Value, int in2Value, int in3Value, int in4Value, int leftSpeed, int rightSpeed) {

  digitalWrite(IN1, in1Value);
  digitalWrite(IN2, in2Value);
  digitalWrite(IN3, in3Value);
  digitalWrite(IN4, in4Value);

  analogWrite(ENA, leftSpeed);
  analogWrite(ENB, rightSpeed);
}

// ================= SETUP =================

void setup() {

  Serial.begin(9600);
  HC05.begin(9600);

  pinMode(INDICATOR_PIN, OUTPUT);

  if (!pcf.begin(0x20, &Wire)) {
    Serial.println("PCF8574 not found!");
    while (1);
  }

  for (uint8_t i = 0; i < 8; i++) {
    pcf.pinMode(i, INPUT);
  }

  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);
  pinMode(ENA, OUTPUT);
  pinMode(ENB, OUTPUT);

  pinMode(TRIGGER_PINF, OUTPUT);
  pinMode(ECHO_PINF, INPUT);
  pinMode(TRIGGER_PINL, OUTPUT);
  pinMode(ECHO_PINL, INPUT);
  pinMode(TRIGGER_PINR, OUTPUT);
  pinMode(ECHO_PINR, INPUT);

  delay(1000);

  Serial.println("Robot Started");
}

// ================= LOOP =================

void loop() {

  int buttonValue = analogRead(BUTTON_PIN);

  static bool lastButtonState = false;
  bool buttonPressed = (buttonValue < BUTTON_THRESHOLD);

  if (buttonPressed && !lastButtonState) {

    currentMode++;

    if (currentMode > MODE_BLUETOOTH) {
      currentMode = MODE_STOP;
    }

    Serial.print("Mode: ");

    if (currentMode == MODE_STOP) Serial.println("STOP");
    else if (currentMode == MODE_LINE_FOLLOW) Serial.println("LINE");
    else if (currentMode == MODE_WALL_FOLLOW) Serial.println("WALL");
    else if (currentMode == MODE_BLUETOOTH) Serial.println("BT");

    delay(300);
  }

  lastButtonState = buttonPressed;

  if (BLINK_DELAY < millisLED) {

    currentLED = !currentLED;
    digitalWrite(INDICATOR_PIN, currentLED);
    millisLED = 0;
  }

  // STOP MODE
  if (currentMode == MODE_STOP) {

    BLINK_DELAY = 10000;

    motorControl(0,0,0,0,0,0);

    delay(50);
    return;
  }

  // ================= BLUETOOTH =================

  if (currentMode == MODE_BLUETOOTH) {

    char c;
    String voice;

    while (HC05.available()) {

      delay(10);
      c = HC05.read();
      voice += c;
    }

    if (voice.length() > 0) {

      Serial.println(voice);

      if (voice == "forward" || voice == "maju" || voice == "A") {

        motorControl(1,0,1,0,60,60);
        delay(1000);
      }

      else if (voice == "backward" || voice == "mundur" || voice == "C") {

        motorControl(0,1,0,1,60,60);
        delay(1000);
      }

      else if (voice == "right" || voice == "kanan" || voice == "B") {

        motorControl(1,0,0,1,60,60);
        delay(1000);
      }

      else if (voice == "left" || voice == "kiri" || voice == "D") {

        motorControl(0,1,1,0,60,60);
        delay(1000);
      }

      voice = "";
    }

    return;
  }

  // ================= WALL FOLLOWER =================

  if (currentMode == MODE_WALL_FOLLOW) {

    BLINK_DELAY = 300;

    long distanceF = getDistance(TRIGGER_PINF, ECHO_PINF);
    long distanceR = getDistance(TRIGGER_PINR, ECHO_PINR);
    long distanceL = getDistance(TRIGGER_PINL, ECHO_PINL);

    Serial.print("F:");
    Serial.print(distanceF);
    //Serial.print(" R:");
    //Serial.print(distanceR);
    Serial.print(" L:");
    Serial.print(distanceL);

     // --- RIGHT WALL FOLLOWING LOGIC ---
  if (distanceF < 10) {
    // Wall in front? Turn left
    motorControl(1,0,0,1,80,80);
    Serial.println(", Obsticale Detected");
  } else if (distanceL > WALL_TARGET + 3) {
    // Wall too far? Veer right to "hug" it
    Serial.println(", Hugging");
    motorControl(1,0,1,0,0,80);
  } else if (distanceL < WALL_TARGET) {
    // Wall too close? Veer left
    motorControl(1,0,1,0,80,0);
    Serial.println(", TOO CLOSE");
  } else {
    // Ideal distance? Move forward
    motorControl(1,0,1,0,80,80);
    Serial.println(", Forward");
  }
}

  // ================= LINE FOLLOWER =================

  if (currentMode == MODE_LINE_FOLLOW) {

    BLINK_DELAY = 500;

    bool LM = !pcf.digitalRead(IR_LEFTMOST);
    bool L  = !pcf.digitalRead(IR_LEFT);
    bool R  = !pcf.digitalRead(IR_RIGHT);
    bool RM = !pcf.digitalRead(IR_RIGHTMOST);

    Serial.print(LM);
    Serial.print(" ");
    Serial.print(L);
    Serial.print(" ");
    Serial.print(R);
    Serial.print(" ");
    Serial.println(RM);

    if (L && R) {

      motorControl(1,0,1,0,LEFT_BASE_SPEED,RIGHT_BASE_SPEED);
    }

    else if (LM || L) {

      motorControl(0,1,1,0,60,60);
    }

    else if (RM || R) {

      motorControl(1,0,0,1,60,60);
    }

    else {

      motorControl(0,0,0,0,0,0);
    }

    delay(15);
  }
}

// ================= ULTRASONIC =================

long getDistance(int triggerPin, int echoPin) {

  digitalWrite(triggerPin, LOW);
  delayMicroseconds(2);

  digitalWrite(triggerPin, HIGH);
  delayMicroseconds(10);

  digitalWrite(triggerPin, LOW);

  long duration = pulseIn(echoPin, HIGH, 30000);

  long distance = duration * 0.034 / 2;

  if (distance == 0 || distance > MAX_DISTANCE) {
    return MAX_DISTANCE;
  }

  return distance;
}
